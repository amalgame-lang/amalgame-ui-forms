import Amalgame.UI.Forms

class Program {
    public static void Main() {
        // ── Theme.Light surface ──────────────────────────
        // Color is from amalgame-ui-sdl (external pkg) so we
        // read fields through GetR/GetG/GetB — direct field
        // access on an incomplete external typedef is rejected
        // by gcc.
        let light: Theme = Theme.Light()
        let surf: Color = light.GetSurface()
        let surfOk: bool = surf.GetR() == 255
        if (surfOk) { surfOk = surf.GetG() == 255 }
        if (surfOk) { surfOk = surf.GetB() == 255 }
        if (surfOk) {
            Console.WriteLine("[PASS] Theme.Light surface white")
        } else {
            Console.WriteLine("[FAIL] Theme.Light surface")
        }

        // ── Theme.Dark background ────────────────────────
        let dark: Theme = Theme.Dark()
        let bg: Color = dark.GetBackground()
        let bgOk: bool = bg.GetR() < 50
        if (bgOk) { bgOk = bg.GetG() < 50 }
        if (bgOk) { bgOk = bg.GetB() < 50 }
        if (bgOk) {
            Console.WriteLine("[PASS] Theme.Dark background dark")
        } else {
            Console.WriteLine("[FAIL] Theme.Dark background")
        }

        // ── Theme.FromOS non-null ────────────────────────
        let osTheme: Theme = Theme.FromOS()
        if (osTheme != null) {
            Console.WriteLine("[PASS] Theme.FromOS non-null")
        } else {
            Console.WriteLine("[FAIL] Theme.FromOS null")
        }

        // ── WidgetKind constants ─────────────────────────
        let wkOk: bool = WidgetKind.LABEL() == 0
        if (wkOk) { wkOk = WidgetKind.BUTTON() == 1 }
        if (wkOk) {
            Console.WriteLine("[PASS] WidgetKind constants")
        } else {
            Console.WriteLine("[FAIL] WidgetKind constants")
        }

        // ── Widget.Label factory ─────────────────────────
        let lbl: Widget = Widget.Label("hi", 0, 0, 80, 24)
        let lblOk: bool = lbl.GetKind() == WidgetKind.LABEL()
        if (lblOk) { lblOk = lbl.GetText() == "hi" }
        if (lblOk) { lblOk = lbl.GetW() == 80 }
        if (lblOk) { lblOk = lbl.GetVisible() }
        if (lblOk) {
            Console.WriteLine("[PASS] Widget.Label factory")
        } else {
            Console.WriteLine("[FAIL] Widget.Label factory")
        }

        // ── Widget.Button + default OnClick flips Pressed ──
        let btn: Widget = Widget.Button("OK", 5, 5, 100, 30)
        let btnOk: bool = btn.GetKind() == WidgetKind.BUTTON()
        if (btnOk) { btnOk = btn.GetText() == "OK" }
        if (btnOk) { btnOk = !btn.GetPressed() }
        if (btnOk) {
            let fakeEv: Event = new Event()
            btn.OnClick(fakeEv)
            btnOk = btn.GetPressed()
        }
        if (btnOk) {
            Console.WriteLine("[PASS] Widget.Button + OnClick")
        } else {
            Console.WriteLine("[FAIL] Widget.Button + OnClick")
        }

        // ── Widget.Contains hit-test ─────────────────────
        let w: Widget = Widget.Label("hit", 10, 20, 100, 50)
        let hitOk: bool = w.Contains(50, 40)
        if (hitOk) { hitOk = !w.Contains(5, 40) }
        if (hitOk) { hitOk = !w.Contains(115, 40) }
        if (hitOk) { hitOk = !w.Contains(50, 80) }
        if (hitOk) { hitOk = w.Contains(10, 20) }
        if (hitOk) { hitOk = !w.Contains(110, 70) }
        if (hitOk) {
            Console.WriteLine("[PASS] Widget.Contains hit-test")
        } else {
            Console.WriteLine("[FAIL] Widget.Contains hit-test")
        }

        // ── Form add + child count ───────────────────────
        let f: Form = new Form("smoke", 320, 240)
        let fOk: bool = f.ChildCount() == 0
        if (fOk) { fOk = f.GetTitle() == "smoke" }
        if (fOk) { fOk = f.GetWidth() == 320 }
        if (fOk) {
            f.Add(lbl)
            f.Add(btn)
            fOk = f.ChildCount() == 2
        }
        if (fOk) {
            Console.WriteLine("[PASS] Form add + child count")
        } else {
            Console.WriteLine("[FAIL] Form add + child count")
        }

        // ── Form.Close flips ShouldClose ─────────────────
        let f2: Form = new Form("close-me", 100, 100)
        let cOk: bool = !f2.ShouldClose()
        if (cOk) {
            f2.Close()
            cOk = f2.ShouldClose()
        }
        if (cOk) {
            Console.WriteLine("[PASS] Form.Close sets ShouldClose")
        } else {
            Console.WriteLine("[FAIL] Form.Close")
        }

        // ── LayoutKind constants ─────────────────────────
        let lkOk: bool = LayoutKind.ABSOLUTE() == 0
        if (lkOk) { lkOk = LayoutKind.STACK_VERTICAL() == 1 }
        if (lkOk) { lkOk = LayoutKind.STACK_HORIZONTAL() == 2 }
        if (lkOk) { lkOk = LayoutKind.GRID() == 3 }
        if (lkOk) {
            Console.WriteLine("[PASS] LayoutKind constants")
        } else {
            Console.WriteLine("[FAIL] LayoutKind constants")
        }

        // ── Layout.StackVertical positions children top-down ──
        // Form 200×400, padding=10, spacing=10, 3 widgets:
        // child width = 200-2*10 = 180; child height =
        // (400-2*10-2*10)/3 = 116 (truncated).
        let stackForm: Form = new Form("stack-v", 200, 400)
        stackForm.Add(Widget.Label("a", 0, 0, 0, 0))
        stackForm.Add(Widget.Label("b", 0, 0, 0, 0))
        stackForm.Add(Widget.Label("c", 0, 0, 0, 0))
        stackForm.SetLayout(Layout.StackVertical(10, 10))
        stackForm.ApplyLayout()
        let svOk: bool = stackForm.GetChild(0).GetX() == 10
        if (svOk) { svOk = stackForm.GetChild(0).GetY() == 10 }
        if (svOk) { svOk = stackForm.GetChild(0).GetW() == 180 }
        if (svOk) { svOk = stackForm.GetChild(1).GetY() == 10 + 116 + 10 }
        if (svOk) { svOk = stackForm.GetChild(2).GetY() == 10 + 2 * (116 + 10) }
        if (svOk) {
            Console.WriteLine("[PASS] Layout.StackVertical")
        } else {
            Console.WriteLine("[FAIL] Layout.StackVertical")
        }

        // ── Layout.StackHorizontal positions children L→R ──
        // Form 400×200, padding=10, spacing=10, 3 widgets:
        // child width = (400-2*10-2*10)/3 = 116; height = 180.
        let hForm: Form = new Form("stack-h", 400, 200)
        hForm.Add(Widget.Label("a", 0, 0, 0, 0))
        hForm.Add(Widget.Label("b", 0, 0, 0, 0))
        hForm.Add(Widget.Label("c", 0, 0, 0, 0))
        hForm.SetLayout(Layout.StackHorizontal(10, 10))
        hForm.ApplyLayout()
        let shOk: bool = hForm.GetChild(0).GetX() == 10
        if (shOk) { shOk = hForm.GetChild(0).GetH() == 180 }
        if (shOk) { shOk = hForm.GetChild(1).GetX() == 10 + 116 + 10 }
        if (shOk) { shOk = hForm.GetChild(2).GetX() == 10 + 2 * (116 + 10) }
        if (shOk) {
            Console.WriteLine("[PASS] Layout.StackHorizontal")
        } else {
            Console.WriteLine("[FAIL] Layout.StackHorizontal")
        }

        // ── Layout.Grid 2×2 ──────────────────────────────
        // Form 220×220, padding=10, spacing=10, 4 cells in 2×2:
        // cw = (220-20-10)/2 = 95; ch = same. Cells:
        //   (0,0)=(10,10), (0,1)=(115,10),
        //   (1,0)=(10,115),(1,1)=(115,115).
        let gForm: Form = new Form("grid", 220, 220)
        gForm.Add(Widget.Label("a", 0, 0, 0, 0))
        gForm.Add(Widget.Label("b", 0, 0, 0, 0))
        gForm.Add(Widget.Label("c", 0, 0, 0, 0))
        gForm.Add(Widget.Label("d", 0, 0, 0, 0))
        gForm.SetLayout(Layout.Grid(2, 2, 10, 10))
        gForm.ApplyLayout()
        let gOk: bool = gForm.GetChild(0).GetX() == 10
        if (gOk) { gOk = gForm.GetChild(1).GetX() == 115 }
        if (gOk) { gOk = gForm.GetChild(2).GetY() == 115 }
        if (gOk) { gOk = gForm.GetChild(3).GetX() == 115 }
        if (gOk) { gOk = gForm.GetChild(3).GetY() == 115 }
        if (gOk) {
            Console.WriteLine("[PASS] Layout.Grid")
        } else {
            Console.WriteLine("[FAIL] Layout.Grid")
        }

        // ── Layout.Absolute leaves children untouched ────
        let aForm: Form = new Form("abs", 320, 240)
        aForm.Add(Widget.Label("a", 42, 99, 50, 20))
        aForm.SetLayout(Layout.Absolute())
        aForm.ApplyLayout()
        let aOk: bool = aForm.GetChild(0).GetX() == 42
        if (aOk) { aOk = aForm.GetChild(0).GetY() == 99 }
        if (aOk) { aOk = aForm.GetChild(0).GetW() == 50 }
        if (aOk) {
            Console.WriteLine("[PASS] Layout.Absolute")
        } else {
            Console.WriteLine("[FAIL] Layout.Absolute")
        }

        // ── Form.Resize repacks via attached layout ──────
        // Resize stackForm 200×400 → 200×220. New child height =
        // (220-20-20)/3 = 60.
        stackForm.Resize(200, 220)
        let rOk: bool = stackForm.GetChild(0).GetH() == 60
        if (rOk) { rOk = stackForm.GetChild(2).GetY() == 10 + 2 * (60 + 10) }
        if (rOk) {
            Console.WriteLine("[PASS] Form.Resize repacks")
        } else {
            Console.WriteLine("[FAIL] Form.Resize repacks")
        }
    }
}
