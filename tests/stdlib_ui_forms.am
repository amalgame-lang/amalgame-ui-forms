import Amalgame.UI.Forms

class Program {
    public static void Main() {
        // ── Theme.Light surface ──────────────────────────
        // Color is from amalgame-ui-sdl (external pkg) so we
        // read fields through GetR/GetG/GetB — direct field
        // access on an incomplete external typedef is rejected
        // by gcc.
        let light: Theme = Theme.Light()
        let surf: Color = light.GetSurface()
        let surfOk: bool = surf.GetR() == 255
        if (surfOk) { surfOk = surf.GetG() == 255 }
        if (surfOk) { surfOk = surf.GetB() == 255 }
        if (surfOk) {
            Console.WriteLine("[PASS] Theme.Light surface white")
        } else {
            Console.WriteLine("[FAIL] Theme.Light surface")
        }

        // ── Theme.Dark background ────────────────────────
        let dark: Theme = Theme.Dark()
        let bg: Color = dark.GetBackground()
        let bgOk: bool = bg.GetR() < 50
        if (bgOk) { bgOk = bg.GetG() < 50 }
        if (bgOk) { bgOk = bg.GetB() < 50 }
        if (bgOk) {
            Console.WriteLine("[PASS] Theme.Dark background dark")
        } else {
            Console.WriteLine("[FAIL] Theme.Dark background")
        }

        // ── Theme.FromOS non-null ────────────────────────
        let osTheme: Theme = Theme.FromOS()
        if (osTheme != null) {
            Console.WriteLine("[PASS] Theme.FromOS non-null")
        } else {
            Console.WriteLine("[FAIL] Theme.FromOS null")
        }

        // ── Widget hit-test ──────────────────────────────
        let w: Widget = new Widget(10, 20, 100, 50)
        let hitOk: bool = w.Contains(50, 40)         // inside
        if (hitOk) { hitOk = !w.Contains(5, 40) }    // outside left
        if (hitOk) { hitOk = !w.Contains(115, 40) }  // outside right
        if (hitOk) { hitOk = !w.Contains(50, 80) }   // outside bottom
        if (hitOk) { hitOk = w.Contains(10, 20) }    // on top-left corner (inclusive)
        if (hitOk) { hitOk = !w.Contains(110, 70) }  // bottom-right (exclusive)
        if (hitOk) {
            Console.WriteLine("[PASS] Widget hit-test")
        } else {
            Console.WriteLine("[FAIL] Widget hit-test")
        }

        // ── Label construction ───────────────────────────
        // Inherited methods (GetW / GetVisible from Widget) must
        // be invoked on a Widget-typed local because the cgen
        // doesn't rewrite Label-receiver method dispatch to walk
        // the base class. Subclass-owned methods (GetText) work
        // directly.
        let lbl: Label = new Label("hi", 0, 0, 80, 24)
        let lblAsWidget: Widget = lbl
        let lblOk: bool = lbl.GetText() == "hi"
        if (lblOk) { lblOk = lblAsWidget.GetW() == 80 }
        if (lblOk) { lblOk = lblAsWidget.GetVisible() }
        if (lblOk) {
            Console.WriteLine("[PASS] Label construction")
        } else {
            Console.WriteLine("[FAIL] Label construction")
        }

        // ── Button construction + default OnClick ────────
        let btn: Button = new Button("OK", 5, 5, 100, 30)
        let btnOk: bool = btn.GetText() == "OK"
        if (btnOk) { btnOk = !btn.GetPressed() }
        if (btnOk) {
            // Simulate a click — default OnClick flips Pressed.
            let fakeEv: Event = new Event()
            btn.OnClick(fakeEv)
            btnOk = btn.GetPressed()
        }
        if (btnOk) {
            Console.WriteLine("[PASS] Button construction + OnClick")
        } else {
            Console.WriteLine("[FAIL] Button construction + OnClick")
        }

        // ── Form add + child count ───────────────────────
        let f: Form = new Form("smoke", 320, 240)
        let fOk: bool = f.ChildCount() == 0
        if (fOk) { fOk = f.GetTitle() == "smoke" }
        if (fOk) { fOk = f.GetWidth() == 320 }
        if (fOk) {
            // Bootstrap typechecker rejects `let w: Widget = lbl`
            // even though Label extends Widget — no implicit
            // upcast at assignment yet. Use plain Widget
            // instances for the child-count smoke; Label/Button
            // membership of Form.Children gets exercised once
            // amc grows the coercion.
            let w1: Widget = new Widget(0, 0, 80, 24)
            let w2: Widget = new Widget(5, 5, 100, 30)
            f.Add(w1)
            f.Add(w2)
            fOk = f.ChildCount() == 2
        }
        if (fOk) {
            Console.WriteLine("[PASS] Form add + child count")
        } else {
            Console.WriteLine("[FAIL] Form add + child count")
        }

        // ── Form.Close flips ShouldClose ─────────────────
        let f2: Form = new Form("close-me", 100, 100)
        let cOk: bool = !f2.ShouldClose()
        if (cOk) {
            f2.Close()
            cOk = f2.ShouldClose()
        }
        if (cOk) {
            Console.WriteLine("[PASS] Form.Close sets ShouldClose")
        } else {
            Console.WriteLine("[FAIL] Form.Close")
        }
    }
}
