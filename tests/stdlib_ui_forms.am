import Amalgame.UI.Forms

class Program {
    public static void Main() {
        // ── Theme.Light surface ──────────────────────────
        // Color is from amalgame-ui-sdl (external pkg) so we
        // read fields through GetR/GetG/GetB — direct field
        // access on an incomplete external typedef is rejected
        // by gcc.
        let light: Theme = Theme.Light()
        let surf: Color = light.GetSurface()
        let surfOk: bool = surf.GetR() == 255
        if (surfOk) { surfOk = surf.GetG() == 255 }
        if (surfOk) { surfOk = surf.GetB() == 255 }
        if (surfOk) {
            Console.WriteLine("[PASS] Theme.Light surface white")
        } else {
            Console.WriteLine("[FAIL] Theme.Light surface")
        }

        // ── Theme.Dark background ────────────────────────
        let dark: Theme = Theme.Dark()
        let bg: Color = dark.GetBackground()
        let bgOk: bool = bg.GetR() < 50
        if (bgOk) { bgOk = bg.GetG() < 50 }
        if (bgOk) { bgOk = bg.GetB() < 50 }
        if (bgOk) {
            Console.WriteLine("[PASS] Theme.Dark background dark")
        } else {
            Console.WriteLine("[FAIL] Theme.Dark background")
        }

        // ── Theme.FromOS non-null ────────────────────────
        let osTheme: Theme = Theme.FromOS()
        if (osTheme != null) {
            Console.WriteLine("[PASS] Theme.FromOS non-null")
        } else {
            Console.WriteLine("[FAIL] Theme.FromOS null")
        }

        // ── WidgetKind constants ─────────────────────────
        let wkOk: bool = WidgetKind.LABEL() == 0
        if (wkOk) { wkOk = WidgetKind.BUTTON() == 1 }
        if (wkOk) {
            Console.WriteLine("[PASS] WidgetKind constants")
        } else {
            Console.WriteLine("[FAIL] WidgetKind constants")
        }

        // ── Widget.Label factory ─────────────────────────
        let lbl: Widget = Widget.Label("hi", 0, 0, 80, 24)
        let lblOk: bool = lbl.GetKind() == WidgetKind.LABEL()
        if (lblOk) { lblOk = lbl.GetText() == "hi" }
        if (lblOk) { lblOk = lbl.GetW() == 80 }
        if (lblOk) { lblOk = lbl.GetVisible() }
        if (lblOk) {
            Console.WriteLine("[PASS] Widget.Label factory")
        } else {
            Console.WriteLine("[FAIL] Widget.Label factory")
        }

        // ── Widget.Button + default OnClick flips Pressed ──
        let btn: Widget = Widget.Button("OK", 5, 5, 100, 30)
        let btnOk: bool = btn.GetKind() == WidgetKind.BUTTON()
        if (btnOk) { btnOk = btn.GetText() == "OK" }
        if (btnOk) { btnOk = !btn.GetPressed() }
        if (btnOk) {
            let fakeEv: Event = new Event()
            btn.OnClick(fakeEv)
            btnOk = btn.GetPressed()
        }
        if (btnOk) {
            Console.WriteLine("[PASS] Widget.Button + OnClick")
        } else {
            Console.WriteLine("[FAIL] Widget.Button + OnClick")
        }

        // ── Widget.Contains hit-test ─────────────────────
        let w: Widget = Widget.Label("hit", 10, 20, 100, 50)
        let hitOk: bool = w.Contains(50, 40)
        if (hitOk) { hitOk = !w.Contains(5, 40) }
        if (hitOk) { hitOk = !w.Contains(115, 40) }
        if (hitOk) { hitOk = !w.Contains(50, 80) }
        if (hitOk) { hitOk = w.Contains(10, 20) }
        if (hitOk) { hitOk = !w.Contains(110, 70) }
        if (hitOk) {
            Console.WriteLine("[PASS] Widget.Contains hit-test")
        } else {
            Console.WriteLine("[FAIL] Widget.Contains hit-test")
        }

        // ── Form add + child count ───────────────────────
        let f: Form = new Form("smoke", 320, 240)
        let fOk: bool = f.ChildCount() == 0
        if (fOk) { fOk = f.GetTitle() == "smoke" }
        if (fOk) { fOk = f.GetWidth() == 320 }
        if (fOk) {
            f.Add(lbl)
            f.Add(btn)
            fOk = f.ChildCount() == 2
        }
        if (fOk) {
            Console.WriteLine("[PASS] Form add + child count")
        } else {
            Console.WriteLine("[FAIL] Form add + child count")
        }

        // ── Form.Close flips ShouldClose ─────────────────
        let f2: Form = new Form("close-me", 100, 100)
        let cOk: bool = !f2.ShouldClose()
        if (cOk) {
            f2.Close()
            cOk = f2.ShouldClose()
        }
        if (cOk) {
            Console.WriteLine("[PASS] Form.Close sets ShouldClose")
        } else {
            Console.WriteLine("[FAIL] Form.Close")
        }

        // ── LayoutKind constants ─────────────────────────
        let lkOk: bool = LayoutKind.ABSOLUTE() == 0
        if (lkOk) { lkOk = LayoutKind.STACK_VERTICAL() == 1 }
        if (lkOk) { lkOk = LayoutKind.STACK_HORIZONTAL() == 2 }
        if (lkOk) { lkOk = LayoutKind.GRID() == 3 }
        if (lkOk) {
            Console.WriteLine("[PASS] LayoutKind constants")
        } else {
            Console.WriteLine("[FAIL] LayoutKind constants")
        }

        // ── Layout.StackVertical positions children top-down ──
        // Form 200×400, padding=10, spacing=10, 3 widgets:
        //   cw = 200 - 2*10                = 180
        //   ch = (400 - 2*10 - 2*10) / 3   = 120
        //
        // Note: bootstrap cgen mangles chained calls like
        // form.GetChild(0).GetX() across package boundaries
        // (`expected ';' before '_GetX'`). Stage every GetChild
        // result in a Widget local first.
        let stackForm: Form = new Form("stack-v", 200, 400)
        stackForm.Add(Widget.Label("a", 0, 0, 0, 0))
        stackForm.Add(Widget.Label("b", 0, 0, 0, 0))
        stackForm.Add(Widget.Label("c", 0, 0, 0, 0))
        stackForm.SetLayout(Layout.StackVertical(10, 10))
        stackForm.ApplyLayout()
        let sv0: Widget = stackForm.GetChild(0)
        let sv1: Widget = stackForm.GetChild(1)
        let sv2: Widget = stackForm.GetChild(2)
        // Expected values hardcoded — `10 + 2 * (120 + 10)` lowers
        // through the same cgen parens-lost bug as Layout.Apply
        // (260 instead of 270 in the emitted C). Hardcoded ints
        // sidestep the precedence breakage at the assertion site.
        let svOk: bool = sv0.GetX() == 10
        if (svOk) { svOk = sv0.GetY() == 10 }
        if (svOk) { svOk = sv0.GetW() == 180 }
        if (svOk) { svOk = sv1.GetY() == 140 }   // 10 + 120 + 10
        if (svOk) { svOk = sv2.GetY() == 270 }   // 10 + 2*(120+10)
        if (svOk) {
            Console.WriteLine("[PASS] Layout.StackVertical")
        } else {
            Console.WriteLine("[FAIL] Layout.StackVertical")
            Console.WriteLine("  sv0 X/Y/W/H = " + String_FromInt(sv0.GetX()) + "/" + String_FromInt(sv0.GetY()) + "/" + String_FromInt(sv0.GetW()) + "/" + String_FromInt(sv0.GetH()))
            Console.WriteLine("  sv1 X/Y/W/H = " + String_FromInt(sv1.GetX()) + "/" + String_FromInt(sv1.GetY()) + "/" + String_FromInt(sv1.GetW()) + "/" + String_FromInt(sv1.GetH()))
            Console.WriteLine("  sv2 X/Y/W/H = " + String_FromInt(sv2.GetX()) + "/" + String_FromInt(sv2.GetY()) + "/" + String_FromInt(sv2.GetW()) + "/" + String_FromInt(sv2.GetH()))
        }

        // ── Layout.StackHorizontal positions children L→R ──
        // Form 400×200, padding=10, spacing=10, 3 widgets:
        //   cw = (400 - 2*10 - 2*10) / 3 = 120
        //   ch = 200 - 2*10              = 180
        let hForm: Form = new Form("stack-h", 400, 200)
        hForm.Add(Widget.Label("a", 0, 0, 0, 0))
        hForm.Add(Widget.Label("b", 0, 0, 0, 0))
        hForm.Add(Widget.Label("c", 0, 0, 0, 0))
        hForm.SetLayout(Layout.StackHorizontal(10, 10))
        hForm.ApplyLayout()
        let sh0: Widget = hForm.GetChild(0)
        let sh1: Widget = hForm.GetChild(1)
        let sh2: Widget = hForm.GetChild(2)
        let shOk: bool = sh0.GetX() == 10
        if (shOk) { shOk = sh0.GetH() == 180 }
        if (shOk) { shOk = sh1.GetX() == 140 }   // 10 + 120 + 10
        if (shOk) { shOk = sh2.GetX() == 270 }   // 10 + 2*(120+10) — hardcoded, see svOk
        if (shOk) {
            Console.WriteLine("[PASS] Layout.StackHorizontal")
        } else {
            Console.WriteLine("[FAIL] Layout.StackHorizontal")
        }

        // ── Layout.Grid 2×2 ──────────────────────────────
        let gForm: Form = new Form("grid", 220, 220)
        gForm.Add(Widget.Label("a", 0, 0, 0, 0))
        gForm.Add(Widget.Label("b", 0, 0, 0, 0))
        gForm.Add(Widget.Label("c", 0, 0, 0, 0))
        gForm.Add(Widget.Label("d", 0, 0, 0, 0))
        gForm.SetLayout(Layout.Grid(2, 2, 10, 10))
        gForm.ApplyLayout()
        let g0: Widget = gForm.GetChild(0)
        let g1: Widget = gForm.GetChild(1)
        let g2: Widget = gForm.GetChild(2)
        let g3: Widget = gForm.GetChild(3)
        let gOk: bool = g0.GetX() == 10
        if (gOk) { gOk = g1.GetX() == 115 }
        if (gOk) { gOk = g2.GetY() == 115 }
        if (gOk) { gOk = g3.GetX() == 115 }
        if (gOk) { gOk = g3.GetY() == 115 }
        if (gOk) {
            Console.WriteLine("[PASS] Layout.Grid")
        } else {
            Console.WriteLine("[FAIL] Layout.Grid")
        }

        // ── Layout.Absolute leaves children untouched ────
        let aForm: Form = new Form("abs", 320, 240)
        aForm.Add(Widget.Label("a", 42, 99, 50, 20))
        aForm.SetLayout(Layout.Absolute())
        aForm.ApplyLayout()
        let a0: Widget = aForm.GetChild(0)
        let aOk: bool = a0.GetX() == 42
        if (aOk) { aOk = a0.GetY() == 99 }
        if (aOk) { aOk = a0.GetW() == 50 }
        if (aOk) {
            Console.WriteLine("[PASS] Layout.Absolute")
        } else {
            Console.WriteLine("[FAIL] Layout.Absolute")
        }

        // ── CheckBox toggle on OnClick ───────────────────
        let cb: Widget = Widget.CheckBox("agree", 0, 0, 100, 24)
        let cbOk: bool = cb.GetKind() == WidgetKind.CHECKBOX()
        if (cbOk) { cbOk = !cb.GetChecked() }
        if (cbOk) {
            let ev: Event = new Event()
            cb.OnClick(ev)
            cbOk = cb.GetChecked()
        }
        if (cbOk) {
            // Second click flips it back.
            let ev2: Event = new Event()
            cb.OnClick(ev2)
            cbOk = !cb.GetChecked()
        }
        if (cbOk) {
            Console.WriteLine("[PASS] CheckBox toggle")
        } else {
            Console.WriteLine("[FAIL] CheckBox toggle")
        }

        // ── RadioButton group exclusivity ────────────────
        // Three radios in group=1, one in group=2. Clicking r0
        // sets Checked=true; UncheckGroup walks the form so r1
        // and r2 (same group) come back to false but r3 (other
        // group) is untouched.
        let radioForm: Form = new Form("radio", 200, 200)
        radioForm.Add(Widget.RadioButton("a", 1, 0, 0, 100, 24))
        radioForm.Add(Widget.RadioButton("b", 1, 0, 0, 100, 24))
        radioForm.Add(Widget.RadioButton("c", 1, 0, 0, 100, 24))
        radioForm.Add(Widget.RadioButton("x", 2, 0, 0, 100, 24))
        let r0: Widget = radioForm.GetChild(0)
        let r1: Widget = radioForm.GetChild(1)
        let r2: Widget = radioForm.GetChild(2)
        let r3: Widget = radioForm.GetChild(3)
        // Pre-check r1 + r3 to ensure UncheckGroup correctly
        // clears group-1 peers while leaving group-2 alone.
        r1.SetChecked(true)
        r3.SetChecked(true)
        // Click r0.
        let rev: Event = new Event()
        r0.OnClick(rev)
        radioForm.UncheckGroup(r0.GetGroup(), r0)
        let radioOk: bool = r0.GetChecked()
        if (radioOk) { radioOk = !r1.GetChecked() }
        if (radioOk) { radioOk = !r2.GetChecked() }
        if (radioOk) { radioOk = r3.GetChecked() }   // group 2 — untouched
        if (radioOk) {
            Console.WriteLine("[PASS] RadioButton group exclusivity")
        } else {
            Console.WriteLine("[FAIL] RadioButton group exclusivity")
        }

        // ── TextBox HandleKey: insert + backspace ────────
        let tb: Widget = Widget.TextBox("hi", 0, 0, 100, 24)
        let tbOk: bool = tb.GetKind() == WidgetKind.TEXTBOX()
        if (tbOk) { tbOk = tb.GetText() == "hi" }
        if (tbOk) { tbOk = tb.GetCursorPos() == 2 }
        // HandleKey ignores events when Focused=false.
        if (tbOk) {
            let ke1: Event = new Event()
            ke1.SetButton(65)   // 'A'
            tb.HandleKey(ke1)
            tbOk = tb.GetText() == "hi"   // unchanged — not focused
        }
        // Focus + type 'A' (SDL keycode 97 = 'a' lower; we use
        // 65 = 'A' upper which is also printable ASCII).
        if (tbOk) {
            tb.SetFocused(true)
            let ke2: Event = new Event()
            ke2.SetButton(65)
            tb.HandleKey(ke2)
            tbOk = tb.GetText() == "hiA"
        }
        if (tbOk) { tbOk = tb.GetCursorPos() == 3 }
        // Backspace removes the freshly-inserted 'A'.
        if (tbOk) {
            let ke3: Event = new Event()
            ke3.SetButton(8)
            tb.HandleKey(ke3)
            tbOk = tb.GetText() == "hi"
        }
        if (tbOk) { tbOk = tb.GetCursorPos() == 2 }
        if (tbOk) {
            Console.WriteLine("[PASS] TextBox insert + backspace")
        } else {
            Console.WriteLine("[FAIL] TextBox insert + backspace")
        }

        // ── Panel construction ───────────────────────────
        let panel: Widget = Widget.Panel(10, 10, 200, 100)
        let panelOk: bool = panel.GetKind() == WidgetKind.PANEL()
        if (panelOk) { panelOk = panel.GetX() == 10 }
        if (panelOk) { panelOk = panel.GetW() == 200 }
        if (panelOk) { panelOk = panel.GetVisible() }
        if (panelOk) {
            Console.WriteLine("[PASS] Panel construction")
        } else {
            Console.WriteLine("[FAIL] Panel construction")
        }

        // ── Form.Resize repacks via attached layout ──────
        // Resize stackForm 200×400 → 200×220. New child height =
        // (220-20-20)/3 = 60.
        //
        // Locals renamed r0/r2 → rz0/rz2 because the bootstrap
        // cgen scopes every `let` at function level (no block-
        // local) and the RADIO test above already declared
        // r0..r3 of the same Widget type.
        stackForm.Resize(200, 220)
        let rz0: Widget = stackForm.GetChild(0)
        let rz2: Widget = stackForm.GetChild(2)
        let rOk: bool = rz0.GetH() == 60
        if (rOk) { rOk = rz2.GetY() == 150 }   // 10 + 2*(60+10) — hardcoded, see svOk
        if (rOk) {
            Console.WriteLine("[PASS] Form.Resize repacks")
        } else {
            Console.WriteLine("[FAIL] Form.Resize repacks")
        }
    }
}
